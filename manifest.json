{
  "manifest_version": 3,
  "name": "Client Tracking Plugin",
  "description": "Трекинг клиентов на целевом сайте с хранением данных в Supabase.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "css": ["src/styles/injected-ui.css"],
      "js": [
        "src/state/storage.js",
        "src/api/supabase-rest.js",
        "src/content/parser.js",
        "src/content/ui.js",
        "src/content/observer.js",
        "src/content/main.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
